# Testing:
#   npm test      — unit tests always run; the event-listener integration
#                   tests additionally need a local Hardhat node reachable at
#                   127.0.0.1:8545 (`cd ../contracts && npx hardhat node`) —
#                   they skip themselves gracefully if none is running.
#   npm run test:e2e — fires a real on-chain threat against the configured
#                   NETWORK below and checks a separately-running agent
#                   picks it up. Run against botchainTestnet first.

# ── Network (BOTchain Mainnet is primary) ─────────────────────────────
NETWORK=botchainMainnet
BOTCHAIN_MAINNET_RPC_URL=https://rpc.botchain.ai
BOTCHAIN_MAINNET_WSS_URL=wss://ws-rpc.botchain.ai

# To run against BOTchain testnet instead, comment the block above and use:
# NETWORK=botchainTestnet
# BOTCHAIN_TESTNET_RPC_URL=https://rpc.bohr.life
# BOTCHAIN_TESTNET_WSS_URL=wss://ws-rpc.bohr.life

# ── Contracts ──────────────────────────────────────────────────────────
# Defaults (in src/config/contracts.ts) already point at the deployed
# BOTchain mainnet/testnet addresses — only set these to override.
# BOTCHAIN_MAINNET_GUARDIAN_VAULT=0xEF650672437A97A7b987984239064D502F56272d
# BOTCHAIN_MAINNET_THREAT_REGISTRY=0x2D101FaFb24C660Bfef07fd3106Caf1074C80bF7

# ── Wallet / signer ────────────────────────────────────────────────────
# Mainnet requires its own key — it never falls back to GUARDIAN_PRIVATE_KEY.
BOTCHAIN_MAINNET_PRIVATE_KEY=
# Used for bscTestnet/bscMainnet/botchainTestnet:
GUARDIAN_PRIVATE_KEY=

# ── Agent config ───────────────────────────────────────────────────────
MONITOR_INTERVAL_MINUTES=5
THREAT_THRESHOLD=75
MAX_PROTECTION_AMOUNT=1000
MONITORED_WALLETS=
MONITORED_TOKENS=
PORT=8080

# ── MongoDB (optional — persistence disabled without it) ──────────────
MONGODB_URI=
MONGODB_DB=guarddog

# ── Telegram (optional) ────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Moltbook (optional) ─────────────────────────────────────────────────
MOLTBOOK_ENABLED=false
MOLTBOOK_API_URL=https://www.moltbook.com
MOLTBOOK_SUBMOLT=lablab
MOLTBOOK_API_KEY=

# ── OpenClaw gateway (optional) ─────────────────────────────────────────
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=
